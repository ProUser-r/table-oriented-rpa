RPA_OCR_URL=http://127.0.0.1:8765
RPA_OCR_DEVICE=gpu
RPA_OCR_TIMEOUT=300

# Optional OpenAI-compatible LLM report.
RPA_LLM_BASE_URL=https://api.openai.com/v1
RPA_LLM_API_KEY=
RPA_LLM_MODEL=gpt-4o-mini

# GUI Automation settings
RPA_GUI_WORKFLOW_DIR=./workflows
RPA_GUI_LOG_LEVEL=INFO
RPA_GUI_BROWSER_HEADLESS=false
RPA_GUI_TIMEOUT=30

# Email credentials (for automated login)
GMAIL_USER=your-email@gmail.com
GMAIL_PASS=your-app-password

# File paths
REPORT_OUTPUT_PATH=C:\\reports\\report.docx
